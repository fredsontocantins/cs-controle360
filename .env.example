# Environment Configuration Variables

# --- Core / data paths ----------------------------------------------------
CS_ENV=development
CS_DATA_DIR=
CS_DB_FILE=
CS_HOMOLOGACAO_FILE=
CS_CUSTOMIZATION_FILE=
CS_SNAPSHOT_FILE=

# --- API key (legacy, still honoured by X-API-Key / ?api_key) -------------
CS_API_KEY=cs-secret

# --- Authentication -------------------------------------------------------
# Signing secret for session cookies (required in production).
CS_SESSION_SECRET=change-me-in-production
# Default admin credentials, used on first boot to seed the users table.
CS_ADMIN_USERNAME=admin
CS_ADMIN_PASSWORD=admin
# Set to 1/true to send the session cookie only over HTTPS.
CS_SESSION_SECURE=0
# Set to 1/true to allow admin access without a session in dev-only scenarios.
CS_ALLOW_UNSECURED_ADMIN=0
